{
  "expo": {
    "name": "filmosaic-mobile",
    "slug": "filmosaic-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "filmosaic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.filmosaic.mobile",
      "infoPlist": {
        "UIRequiresFullScreen": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C1C1E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.filmosaic.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "expo-splash-screen",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "backgroundColor": "#1C1C1E",
      "image": "./assets/splash.png",
      "resizeMode": "contain"
    },
    "extra": {
      "eas": {
        "projectId": "filmosaic-mobile"
      }
    }
  }
}
